                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{status} != null && !$F{status}.isEmpty() ? $F{status}.substring(0,1).toUpperCase() + $F{status}.substring(1).toLowerCase() : ""]]></textFieldExpression>
