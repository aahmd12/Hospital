        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30" uuid="9c8d7e6f-5a4b-3c2d-1e0f-9a8b7c6d5e4f"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
